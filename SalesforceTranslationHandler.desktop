[Desktop Entry]
Type=Application
Name=Salesforce Translation Manager
Comment=STF -> Excel -> Translate -> Review -> STF workflow
Exec=bash -c 'cd "$(dirname %k)" && exec ./launch.sh'
# --- Icon installation ---
# The Icon field below uses a placeholder path. After cloning the repository,
# run this command from the repo root to set the correct absolute path:
#
#   sed -i "s|^Icon=.*|Icon=$(pwd)/src/stx/gui/assets/logo.png|" SalesforceTranslationHandler.desktop
#
# Then copy the patched file to your applications directory:
#
#   cp SalesforceTranslationHandler.desktop ~/.local/share/applications/
#
# If you move the repository later, re-run the sed command and copy again.
Icon=src/stx/gui/assets/logo.png
Terminal=false
Categories=Utility;Development;
StartupNotify=true
